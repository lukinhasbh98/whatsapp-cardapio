# Porta do servidor web
PORT=3000

# Senha de acesso ao painel admin
ADMIN_PASSWORD=suasenha

# Segredo para gerar tokens JWT
JWT_SECRET=troque_por_uma_string_aleatoria_longa

# Token de acesso do Mercado Pago
# Obtenha em: https://www.mercadopago.com.br/settings/account/credentials
MP_ACCESS_TOKEN=APP_USR-000000000000000-000000-00000000000000000000000000000000-000000000

# Segredo para validar assinatura dos webhooks do Mercado Pago
# Configure em: Mercado Pago > Suas integrações > Webhooks
MP_WEBHOOK_SECRET=

# URL pública do servidor (necessária para o Mercado Pago enviar webhooks)
# Em produção: https://seudominio.com
# Em desenvolvimento local: use ngrok (ex: https://abc123.ngrok.io)
WEBHOOK_BASE_URL=https://seudominio.com
